{
  "name": "classlint-server",
  "version": "1.0.0",
  "description": "manage schedules application",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"No tests configured\"",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "concurrently \"npx tsc --watch --preserveWatchOutput\" \"nodemon dist/index.js\"",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oussama-drifi/ClassLint-Server"
  },
  "author": "oussama drifi",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.3",
    "drizzle-kit": "^1.0.0-rc.4",
    "nodemon": "^3.1.14",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
